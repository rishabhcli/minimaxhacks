# ShieldDesk AI — Environment Variables
# Copy to .env and fill in all values before running.

# ========== MiniMax (Platinum) ==========
# LLM brain + embeddings for RAG
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5
# Note: GroupId is NOT required for the OpenAI-compatible API.

# ========== VAPI (Gold) ==========
# Voice AI orchestration — web widget + call management
VAPI_PUBLIC_KEY=                # For browser SDK (@vapi-ai/web)
VAPI_PRIVATE_KEY=               # For server-side API calls
VAPI_ASSISTANT_ID=              # Created via setup script or dashboard

# ========== Convex (Gold) ==========
# Real-time database, RAG, Agent Threads
CONVEX_URL=                     # https://<deployment>.convex.cloud
CONVEX_DEPLOY_KEY=              # For ConvexHttpClient auth from backend
NEXT_PUBLIC_CONVEX_URL=         # Same as CONVEX_URL, exposed to Next.js client

# ========== Speechmatics (Gold) ==========
# Real-time STT for Plivo phone channel + sentiment analysis
SPEECHMATICS_API_KEY=

# ========== Plivo (Silver) ==========
# Telephony (phone channel) + SMS confirmations
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=             # E.164 format, e.g. +14155551234

# ========== ElevenLabs (Bronze) ==========
# Text-to-speech — used by VAPI natively + Plivo phone channel
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=            # Choose from ElevenLabs voice library

# ========== rtrvr.ai (Bronze) ==========
# Web scraping for RAG knowledge base
RTRVR_API_KEY=

# ========== ArmorIQ (Bronze) ==========
# Cryptographic policy enforcement for agent actions
ARMORIQ_API_KEY=
ARMORIQ_USER_ID=                # Identifies the calling user/team
ARMORIQ_AGENT_ID=               # Identifies this agent in the registry

# ========== Server ==========
PORT=3000                       # API server port
MCP_SERVER_URL=http://localhost:3001/mcp
PUBLIC_URL=https://your-domain.com   # For Plivo Answer URL + VAPI custom LLM endpoint
